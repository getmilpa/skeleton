parameters:
    level: 6
    paths:
        - src
        - public
    # Agent-ready is OPT-IN: milpa/tool-runtime is a require-dev/opt-in dependency of this
    # skeleton (HttpProjector's scope enforcement needs it, and the test + analysis toolchain
    # ship it), but a PRODUCTION `--no-dev` install does not — so every runtime use is guarded
    # by class_exists()/instanceof and degrades cleanly when the package is absent. Analysis DOES
    # see the concrete classes (dev deps installed), so the only residual note is the defensive
    # instanceof below: it proves at runtime that a host-installed tool-runtime's registry still
    # implements core's interface, which phpstan reads as always-true against the pinned version
    # but which still guards a different version at production runtime. Scoped to the one line.
    ignoreErrors:
        -
            message: '#^Instanceof between Milpa\\ToolRuntime\\ToolRegistry and Milpa\\Interfaces\\Tooling\\ToolRegistryInterface will always evaluate to true\.$#'
            path: src/Console/Application.php
