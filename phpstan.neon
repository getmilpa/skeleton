parameters:
    level: 6
    paths:
        - src
        - public
    # Agent-ready is OPT-IN: milpa/tool-runtime is suggest-only, so the BASE install this
    # analysis runs against does not ship Milpa\ToolRuntime\ToolRegistry — the class is
    # unknown here by design, not by accident. The code guards every use at runtime
    # (class_exists() before constructing, instanceof before narrowing) and inspect:tools
    # degrades to teaching the opt-in command instead of failing. Scoped to the one file
    # and the one class so any OTHER missing symbol still fails the analysis.
    ignoreErrors:
        -
            message: '#^Class Milpa\\ToolRuntime\\ToolRegistry not found\.$#'
            path: src/Console/Application.php
        -
            message: '#^Call to method getToolSummaries\(\) on an unknown class Milpa\\ToolRuntime\\ToolRegistry\.$#'
            path: src/Console/Application.php
